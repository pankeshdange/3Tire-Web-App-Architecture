# Environment Configuration - App Tier
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DB_HOST=my-project-db-instance-1.ccrkwa0kcneo.us-east-1.rds.amazonaws.com
DB_USER=admin
DB_PWD=admin123
DB_DATABASE=webappdb

# API Configuration
API_TIMEOUT=30000
MAX_REQUEST_SIZE=10mb

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
